# ── Firebase Web App Credentials ───────────────────────────────────────────
# Copy this file to `.env` and fill in values from your Firebase console:
#   1. https://console.firebase.google.com/ → create a project
#   2. Project settings → General → Your apps → Web app → SDK setup & config
#   3. Enable Email/Password sign-in: Authentication → Sign-in method
#   4. Enable Firestore: Build → Firestore Database → Create
#   5. Restart `npm run dev` after saving this file.
#
# Leave these blank to run in local-only demo mode (accounts live in your
# browser's localStorage; no cloud sync).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=payoff-65122
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
